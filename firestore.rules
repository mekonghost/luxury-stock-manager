rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isStaff() {
      return isSignedIn() && request.auth.token.email != null && (
        request.auth.token.email.matches('(?i)stuff@luxurypaint\\.com') || 
        request.auth.token.email.matches('(?i)staff@luxurypaint\\.com') || 
        request.auth.token.email.matches('(?i)mekonghost@gmail\\.com') ||
        request.auth.token.email.matches('(?i).*@luxury-paint\\.com')
      );
    }

    function isCustomer() {
      return isSignedIn() && request.auth.token.email != null && request.auth.token.email.matches('(?i)customer@luxurypaint\\.com');
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isNumeric(val) {
      return val is int || val is float;
    }

    // 1. Validation Blueprints
    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'quantity', 'ownerId', 'updatedAt', 'section', 'unit'])
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && isNumeric(data.quantity)
        && data.unit is string && data.unit.size() <= 50
        && data.section in ['Materials', 'Finish']
        && data.updatedAt == request.time
        && (data.get('category', '') is string)
        && isNumeric(data.get('minStockLevel', 0))
        && (data.get('grade', '') is string && data.get('grade', '').size() <= 100)
        && (data.get('barcode', '') is string)
        && (data.get('description', '') is string)
        && (data.get('availableSizes', []) is list)
        && (data.get('availableBases', []) is list)
        && (data.get('finishStocks', {}) is map);
    }

    function isValidLog(data) {
      return data.keys().hasAll(['productId', 'productName', 'amount', 'unit', 'previousQuantity', 'newQuantity', 'ownerId', 'createdAt', 'type'])
        && isNumeric(data.amount)
        && data.unit is string && data.unit.size() <= 50
        && data.type in ['INTAKE', 'OUTTAKE']
        && data.createdAt == request.time
        && (data.get('grade', '') is string && data.get('grade', '').size() <= 100)
        && (data.get('size', '') is string && data.get('size', '').size() <= 100)
        && (data.get('section', 'Materials') in ['Materials', 'Finish'])
        && isNumeric(data.previousQuantity)
        && isNumeric(data.newQuantity);
    }

    match /products/{productId} {
      allow read: if isSignedIn();
      
      allow create: if isStaff() 
        && isValidProduct(incoming())
        && isValidId(productId);
      
      allow update: if isStaff()
        && isValidProduct(incoming());
        
      allow delete: if isStaff();
    }

    match /stock_logs/{logId} {
      allow list, get: if isSignedIn();
      allow create: if isStaff() && isValidLog(incoming());
      allow update, delete: if false;
    }

    match /user_permissions_config/{userEmail} {
      allow get: if true;
      allow list: if isSignedIn();
      allow write: if isStaff();
    }
  }
}
